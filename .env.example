NODE_ENV=production
PORT=3000
APP_URL=https://atlasachievement.com.br
CANONICAL_ORIGIN=https://atlasachievement.com.br
CORS_ALLOWED_ORIGINS=https://atlasachievement.com.br
GA_MEASUREMENT_ID=G-QNPM6F50XY

# Resident Evil 5 — flags de preparação para produção. Manter desligadas até
# CMP, revisão jurídica, configuração real e rollout autorizados.
RE5_PRODUCT_ANALYTICS_ENABLED=false
RE5_CWV_ENABLED=false
RE5_ERROR_MONITORING_ENABLED=false
RE5_ADS_ENABLED=false
RE5_ADS_TEST_PLACEHOLDERS=false
RE5_ADS_PLACEMENT_SUMMARY_ENABLED=true
RE5_ADS_PLACEMENT_ROADMAP_ENABLED=true
RE5_ADS_PLACEMENT_EXTRAS_ENABLED=true
RE5_ADS_PLACEMENT_DLC_ENABLED=true
SESSION_SECRET=troque-por-uma-chave-longa-e-segura
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-essa-senha
ALLOW_DEFAULT_ADMIN_BOOTSTRAP=false
AUTO_IMPORT_GUIDES_ON_START=false
DATABASE_PATH=/data/database.sqlite
UPLOAD_DIR=./public/uploads
MAX_UPLOAD_SIZE_BYTES=5242880
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
LOGIN_BLOCK_DURATION_MS=900000

SESSION_MAX_AGE_HOURS=8
SESSION_CLEANUP_INTERVAL_MINUTES=30
